# ============================================================
# AmoreSync — Environment Variables for Vercel Deployment
# ============================================================
# Copy this file ke .env.local untuk development lokal.
# Di Vercel, isi variabel ini di:
#   Project Settings → Environment Variables

# ── Supabase ─────────────────────────────────────────────────
# Dapatkan dari: https://app.supabase.com → Project → Settings → API

# URL project Supabase kamu
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon/public key (aman di-expose ke client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY

# ── Optional: Untuk fitur lanjutan ───────────────────────────
# Service Role Key (RAHASIA! Jangan pernah expose ke client)
# Hanya gunakan di server-side jika perlu admin access
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...YOUR_SERVICE_ROLE_KEY

# ── App URL (otomatis di Vercel) ──────────────────────────────
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ============================================================
# CHECKLIST SEBELUM DEPLOY KE VERCEL:
# ============================================================
# [ ] NEXT_PUBLIC_SUPABASE_URL sudah diisi
# [ ] NEXT_PUBLIC_SUPABASE_ANON_KEY sudah diisi
# [ ] Di Supabase: Authentication → URL Configuration
#     → Site URL = https://your-app.vercel.app
#     → Redirect URLs += https://your-app.vercel.app/**
# [ ] Di Supabase: Storage → Bucket 'avatars' sudah dibuat
# [ ] Di Supabase: Database → RLS policies sudah aktif
# ============================================================
